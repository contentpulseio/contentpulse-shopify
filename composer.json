{
    "name": "contentpulse/shopify-app",
    "description": "ContentPulse Shopify integration — sync AI-generated content to Shopify stores.",
    "type": "project",
    "license": "MIT",
    "keywords": ["contentpulse", "shopify", "content", "seo", "ai"],
    "homepage": "https://github.com/contentpulseio/contentpulse-shopify",
    "authors": [
        {
            "name": "ContentPulse",
            "email": "dev@contentpulse.io"
        }
    ],
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.8",
        "contentpulse/contentpulse-php": "@dev",
        "shopify/shopify-api": "^6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "laravel/pint": "^1.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "ContentPulse\\Shopify\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ContentPulse\\Shopify\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../contentpulse-php-sdk",
            "options": {
                "symlink": true
            }
        }
    ],
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
